{
  "name": "islandty",
  "version": "1.0.0",
  "description": "A static site generator for Islandora Workbench data.",
  "main": ".eleventy.js",
  "scripts": {
    "clean": "node src/islandty/commands/clean.js",
    "readcsv": "node src/islandty/commands/readCSV.js",
    "compileLocalMirador": "node src/islandty/commands/compileMirador.js",
    "start": "npm run compileLocalMirador && node src/islandty/commands/readCSV.js && npx gulp && concurrently \"npx gulp watch\" \"npx eleventy --serve\"",
    "production": "npm run compileLocalMirador && node src/islandty/commands/readCSV.js && NODE_ENV=production npx gulp && NODE_ENV=production npx eleventy",
    "test": "NODE_ENV=test vitest run",
    "test:mirador": "compile_mirador=true node src/islandty/commands/compileMirador.js && NODE_ENV=test vitest run tests/unit/mirador.test.js",
    "test:watch": "NODE_ENV=test vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@11ty/eleventy-plugin-rss": "^2.0.3",
    "@alxp/biiif": "github:alxp/biiif#master-dist",
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@mui/material": "^7.0.0",
    "@mui/system": "^7.0.0",
    "@ocfl/ocfl-fs": "^0.2.2",
    "concurrently": "^9.1.2",
    "csv": "^6.3.8",
    "dotenv": "^17.1.0",
    "eleventy-plugin-mirador": "^2.0.1",
    "glob": "^13.0.6",
    "gulp": "^5.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-rename": "^2.0.0",
    "html-minifier-terser": "^7.2.0",
    "install": "^0.13.0",
    "lunr": "^2.3.9",
    "mirador": "^4.0.0",
    "mirador-textoverlay": "github:dbmdz/mirador-textoverlay#main",
    "moment": "^2.30.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "saxon-js": "^2.6.0",
    "sharp": "^0.33.5",
    "string-strip-html": "^8.3.0",
    "uuid": "^11.1.0",
    "vue": "^3.5.13",
    "write-yaml-file": "^5.0.0",
    "xslt-processor": "^3.3.1",
    "xslt3": "^2.6.0"
  },
  "overrides": {
    "node-gyp": "^12.3.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  }
}
